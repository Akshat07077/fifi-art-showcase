# Copy to .env — only VITE_* vars are available in the browser

# Content preset: fifi | inknova
VITE_CONTENT_PRESET=fifi

VITE_SITE_URL=http://localhost:5173

VITE_STUDIO_NAME=Studio Name
VITE_ARTIST_NAME=Artist
VITE_STUDIO_LEGAL_NAME=Studio Name Studio
VITE_STUDIO_TAGLINE=Handpoke & Machine
VITE_SITE_DESCRIPTION=Short SEO description for the studio.

VITE_INSTAGRAM_HANDLE=yourhandle
VITE_WHATSAPP_NUMBER=919999999999
VITE_STUDIO_EMAIL=hello@studio.com

VITE_STUDIO_STREET=Street Address
VITE_STUDIO_CITY=City
VITE_STUDIO_POSTAL_CODE=000000
VITE_STUDIO_COUNTRY=IN

VITE_STUDIO_HOURS_DAYS=Mon — Fri
VITE_STUDIO_HOURS_TIME=10:00 – 18:00
VITE_APPOINTMENT_LABEL=By Appointment
VITE_PRICE_RANGE=₹₹
